// SwissAgent Native — Windows application manifest
// This file declares that the app requires Windows 10+ and that it is
// DPI-aware and that the WebView2 Runtime is activated correctly.

#include "resource.h"

// Application icon
IDI_APP_ICON  ICON  "../assets/icon.ico"
IDI_TRAY_ICON ICON  "../assets/icon.ico"

// Embed the application manifest so Windows activates the correct Visual C++
// runtime and marks this as a long-path-aware, DPI-aware application.
1 24 "app.manifest"
